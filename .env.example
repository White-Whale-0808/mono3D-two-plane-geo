# 複製此檔案為 .env 並填入本機路徑（.env 已加入 .gitignore，不會進版本控制）

# CARLA Python wheel 路徑（依安裝位置調整）
CARLA_WHL_PATH=D:/CARLA_0.9.16/PythonAPI/carla/dist/carla-0.9.16-cp312-cp312-win_amd64.whl

# OpenCV DLL 資料夾（解決 import cv2 時 ImportError: DLL load failed）
OPENCV_BIN_PATH=C:\Users\YourName\Downloads\opencv\build\x64\vc16\bin
